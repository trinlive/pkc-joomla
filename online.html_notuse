<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบจองคิวทำบัตรประจำตัวประชาชน สำนักทะเบียนท้องถิ่นเทศบาลนครปากเกร็ด</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Sarabun', sans-serif;
        }
        
        .gradient-bg {
            background: linear-gradient(135deg, #3b82f6 0%, #1e40af 100%);
        }
        
        .card-shadow {
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
        
        .input-focus:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }
        
        .btn-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
        }
        
        .success-animation {
            animation: successPulse 0.6s ease-in-out;
        }
        
        @keyframes successPulse {
            0% { transform: scale(0.8); opacity: 0; }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); opacity: 1; }
        }
        
        .loading-spinner {
            border: 3px solid #f3f4f6;
            border-top: 3px solid #3b82f6;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="min-h-screen gradient-bg">
    <div class="container mx-auto px-4 py-8">
        <!-- Header -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-white rounded-full mb-4 card-shadow">
                <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
            </div>
            <h1 class="text-4xl font-bold text-white mb-2">ระบบจองคิวทำบัตรประจำตัวประชาชน</h1>
            <p class="text-blue-100 text-lg">กรุณากรอกข้อมูลเพื่อจองคิวของคุณ</p>
        </div>

        <!-- Main Form Card -->
        <div class="max-w-2xl mx-auto">
            <div class="bg-white rounded-2xl card-shadow overflow-hidden">
                <!-- Form Header -->
                <div class="bg-gradient-to-r from-blue-50 to-blue-100 px-8 py-6 border-b border-blue-200">
                    <h2 class="text-2xl font-semibold text-blue-800 flex items-center">
                        <svg class="w-6 h-6 mr-3 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a2 2 0 012-2h4a2 2 0 012 2v4m-6 0V6a2 2 0 012-2h4a2 2 0 012 2v1m-6 0h8m-8 0H6a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-2"></path>
                        </svg>
                        ข้อมูลการจองคิว
                    </h2>
                </div>

                <!-- Form Body -->
                <form id="queueForm" class="p-8 space-y-6">
                    <!-- สถานที่ -->
                    <div class="space-y-2">
                        <label for="location" class="block text-sm font-medium text-gray-700 flex items-center">
                            <svg class="w-4 h-4 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                            สถานที่ *
                        </label>
                        <select id="location" name="location" required class="w-full px-4 py-3 border border-gray-300 rounded-lg input-focus transition-all duration-200 bg-white">
                            <option value="">เลือกสถานที่</option>
                            <option value="สำนักงานเทศบาลนครปากเกร็ด">สำนักงานเทศบาลนครปากเกร็ด</option>
                            <option value="ศูนยการค้าคอสโม บาซาร์ เมืองทองธานี">ศูนยการค้าคอสโม บาซาร์ เมืองทองธานี</option>
                            <option value="ศูนย์การแพทย์ปัญญานันทภิกขุชลประทาน">ศูนย์การแพทย์ปัญญานันทภิกขุชลประทาน</option>
                        </select>
                    </div>

                    <!-- วันที่และเวลา -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label for="date" class="block text-sm font-medium text-gray-700 flex items-center">
                                <svg class="w-4 h-4 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a2 2 0 012-2h4a2 2 0 012 2v4m-6 0V6a2 2 0 012-2h4a2 2 0 012 2v1m-6 0h8m-8 0H6a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-2"></path>
                                </svg>
                                วันที่ *
                            </label>
                            <input type="date" id="date" name="date" required class="w-full px-4 py-3 border border-gray-300 rounded-lg input-focus transition-all duration-200">
                        </div>
                        
                        <div class="space-y-2">
                            <label for="time" class="block text-sm font-medium text-gray-700 flex items-center">
                                <svg class="w-4 h-4 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                เวลา *
                            </label>
                            <select id="time" name="time" required class="w-full px-4 py-3 border border-gray-300 rounded-lg input-focus transition-all duration-200 bg-white">
                                <option value="">เลือกเวลา</option>
                            </select>
                        </div>
                    </div>

                    <!-- ชื่อและเบอร์โทร -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label for="name" class="block text-sm font-medium text-gray-700 flex items-center">
                                <svg class="w-4 h-4 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                                ชื่อ-นามสกุล *
                            </label>
                            <input type="text" id="name" name="name" required placeholder="กรุณากรอกชื่อ-นามสกุล" class="w-full px-4 py-3 border border-gray-300 rounded-lg input-focus transition-all duration-200">
                        </div>
                        
                        <div class="space-y-2">
                            <label for="phone" class="block text-sm font-medium text-gray-700 flex items-center">
                                <svg class="w-4 h-4 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                                </svg>
                                เบอร์โทรศัพท์ *
                            </label>
                            <input type="tel" id="phone" name="phone" required placeholder="0XX-XXX-XXXX" pattern="[0-9]{10}" class="w-full px-4 py-3 border border-gray-300 rounded-lg input-focus transition-all duration-200">
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <div class="pt-4">
                        <button type="submit" id="submitBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 px-6 rounded-lg transition-all duration-300 btn-hover flex items-center justify-center space-x-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <span>บันทึกการจองคิว</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Success Modal -->
        <div id="successModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
            <div class="bg-white rounded-2xl p-8 max-w-lg mx-4 card-shadow success-animation">
                <div class="text-center">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                    </div>
                    <h3 class="text-2xl font-semibold text-gray-800 mb-4">จองคิวสำเร็จ!</h3>
                    
                    <!-- Booking Summary -->
                    <div class="bg-blue-50 rounded-lg p-6 mb-6 text-left">
                        <h4 class="text-lg font-semibold text-blue-800 mb-4 text-center flex items-center justify-center">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                            สรุปข้อมูลการจองคิว
                        </h4>
                        <div class="space-y-3">
                            <div class="flex items-start">
                                <svg class="w-4 h-4 text-blue-600 mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                                <div>
                                    <span class="text-sm text-gray-600">สถานที่:</span>
                                    <p class="font-medium text-gray-800" id="summaryLocation"></p>

                                </div>
                            </div>
                            <div class="flex items-start">
                                <svg class="w-4 h-4 text-blue-600 mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a2 2 0 012-2h4a2 2 0 012 2v4m-6 0V6a2 2 0 012-2h4a2 2 0 012 2v1m-6 0h8m-8 0H6a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-2"></path>
                                </svg>
                                <div>
                                    <span class="text-sm text-gray-600">วันที่:</span>
                                    <p class="font-medium text-gray-800" id="summaryDate"></p>
                                </div>
                            </div>
                            <div class="flex items-start">
                                <svg class="w-4 h-4 text-blue-600 mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                <div>
                                    <span class="text-sm text-gray-600">เวลา:</span>
                                    <p class="font-medium text-gray-800" id="summaryTime"></p>
                                </div>
                            </div>
                            <div class="flex items-start">
                                <svg class="w-4 h-4 text-blue-600 mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                                <div>
                                    <span class="text-sm text-gray-600">ชื่อ-นามสกุล:</span>
                                    <p class="font-medium text-gray-800" id="summaryName"></p>
                                </div>
                            </div>
                            <div class="flex items-start">
                                <svg class="w-4 h-4 text-blue-600 mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                                </svg>
                                <div>
                                    <span class="text-sm text-gray-600">เบอร์โทรศัพท์:</span>
                                    <p class="font-medium text-gray-800" id="summaryPhone"></p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <p class="text-gray-600 mb-6 text-sm">กรุณาเตรียมเอกสารที่จำเป็นและมาตามวันเวลาที่จองไว้</p>
                    <button onclick="closeModal()" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-all duration-200">
                        ตกลง
                    </button>
                </div>
            </div>
        </div>

        <!-- Error Modal -->
        <div id="errorModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
            <div class="bg-white rounded-2xl p-8 max-w-md mx-4 card-shadow">
                <div class="text-center">
                    <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </div>
                    <h3 class="text-2xl font-semibold text-gray-800 mb-2">เกิดข้อผิดพลาด</h3>
                    <p class="text-gray-600 mb-6" id="errorMessage">ไม่สามารถส่งข้อมูลได้ กรุณาลองใหม่อีกครั้ง</p>
                    <button onclick="closeErrorModal()" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-3 px-6 rounded-lg transition-all duration-200">
                        ตกลง
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Set minimum date to today
        document.getElementById('date').min = new Date().toISOString().split('T')[0];

        // Government holidays for 2024-2025 (Thai holidays)
        const governmentHolidays = [
            '2024-01-01', // วันขึ้นปีใหม่
            '2024-02-24', // วันมาฆบูชา
            '2024-04-06', // วันจักรี
            '2024-04-13', // วันสงกรานต์
            '2024-04-14', // วันสงกรานต์
            '2024-04-15', // วันสงกรานต์
            '2024-05-01', // วันแรงงาน
            '2024-05-04', // วันฉัตรมงคล
            '2024-05-22', // วันวิสาขบูชา
            '2024-06-03', // วันเฉลิมพระชนมพรรษาสมเด็จพระนางเจ้าฯ
            '2024-07-20', // วันอาสาฬหบูชา
            '2024-07-21', // วันเข้าพรรษา
            '2024-07-28', // วันเฉลิมพระชนมพรรษาพระบาทสมเด็จพระเจ้าอยู่หัว
            '2024-08-12', // วันเฉลิมพระชนมพรรษาสมเด็จพระนางเจ้าสิริกิติ์
            '2024-10-13', // วันคล้ายวันสวรรคตพระบาทสมเด็จพระบรมชนกาธิเบศร
            '2024-10-23', // วันปิยมหาราช
            '2024-12-05', // วันคล้ายวันพระบาทสมเด็จพระบรมชนกาธิเบศร
            '2024-12-10', // วันรัฐธรรมนูญ
            '2024-12-31', // วันสิ้นปี
            '2025-01-01', // วันขึ้นปีใหม่
            '2025-02-12', // วันมาฆบูชา
            '2025-04-06', // วันจักรี
            '2025-04-13', // วันสงกรานต์
            '2025-04-14', // วันสงกรานต์
            '2025-04-15', // วันสงกรานต์
            '2025-05-01', // วันแรงงาน
            '2025-05-04', // วันฉัตรมงคล
            '2025-05-10', // วันวิสาขบูชา
            '2025-06-03', // วันเฉลิมพระชนมพรรษาสมเด็จพระนางเจ้าฯ
            '2025-07-08', // วันอาสาฬหบูชา
            '2025-07-09', // วันเข้าพรรษา
            '2025-07-28', // วันเฉลิมพระชนมพรรษาพระบาทสมเด็จพระเจ้าอยู่หัว
            '2025-08-12', // วันเฉลิมพระชนมพรรษาสมเด็จพระนางเจ้าสิริกิติ์
            '2025-10-13', // วันคล้ายวันสวรรคตพระบาทสมเด็จพระบรมชนกาธิเบศร
            '2025-10-23', // วันปิยมหาราช
            '2025-12-05', // วันคล้ายวันพระบาทสมเด็จพระบรมชนกาธิเบศร
            '2025-12-10', // วันรัฐธรรมนูญ
            '2025-12-31'  // วันสิ้นปี
        ];

        // Function to check if date is weekend or holiday
        function isWeekendOrHoliday(dateString) {
            const date = new Date(dateString);
            const dayOfWeek = date.getDay(); // 0 = Sunday, 6 = Saturday
            
            // Check if weekend (Saturday = 6, Sunday = 0)
            if (dayOfWeek === 0 || dayOfWeek === 6) {
                return true;
            }
            
            // Check if government holiday
            if (governmentHolidays.includes(dateString)) {
                return true;
            }
            
            return false;
        }

        // Time slots for each location
        const timeSlots = {
            'สำนักงานเทศบาลนครปากเกร็ด': [
                '13:00', '13:30', '14:00', '15:00', '15:30', '16:00'
            ],
            'ศูนยการค้าคอสโม บาซาร์ เมืองทองธานี': [
                '13:00', '13:30', '15:00', '15:30', '16:00', '16:30'
            ],
            'ศูนย์การแพทย์ปัญญานันทภิกขุชลประทาน': [
                '13:00', '13:30', '14:00', '15:00', '15:30', '16:00'
            ]
        };

        // Update time options based on selected location
        document.getElementById('location').addEventListener('change', function(e) {
            const selectedLocation = e.target.value;
            const timeSelect = document.getElementById('time');
            
            // Clear existing options except the first one
            timeSelect.innerHTML = '<option value="">เลือกเวลา</option>';
            
            if (selectedLocation && timeSlots[selectedLocation]) {
                timeSlots[selectedLocation].forEach(time => {
                    const option = document.createElement('option');
                    option.value = time;
                    option.textContent = time + ' น.';
                    timeSelect.appendChild(option);
                });
            }
        });

        // Date input validation
        document.getElementById('date').addEventListener('change', function(e) {
            const selectedDate = e.target.value;
            
            if (isWeekendOrHoliday(selectedDate)) {
                const date = new Date(selectedDate);
                const dayOfWeek = date.getDay();
                let message = '';
                
                if (dayOfWeek === 0) {
                    message = 'ไม่สามารถจองคิวในวันอาทิตย์ได้ กรุณาเลือกวันจันทร์-ศุกร์';
                } else if (dayOfWeek === 6) {
                    message = 'ไม่สามารถจองคิวในวันเสาร์ได้ กรุณาเลือกวันจันทร์-ศุกร์';
                } else {
                    message = 'วันที่เลือกเป็นวันหยุดราชการ กรุณาเลือกวันทำการ';
                }
                
                showErrorModal(message);
                e.target.value = '';
            }
        });

        // Phone number formatting
        document.getElementById('phone').addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length > 10) value = value.slice(0, 10);
            e.target.value = value;
        });

        // Form submission
        document.getElementById('queueForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const submitBtn = document.getElementById('submitBtn');
            const originalContent = submitBtn.innerHTML;
            
            // Show loading state
            submitBtn.innerHTML = `
                <div class="loading-spinner"></div>
                <span>กำลังส่งข้อมูล...</span>
            `;
            submitBtn.disabled = true;
            
            // Collect form data
            const formData = new FormData();
            formData.append('location', document.getElementById('location').value);
            formData.append('date', document.getElementById('date').value);
            formData.append('time', document.getElementById('time').value);
            formData.append('name', document.getElementById('name').value);
            formData.append('phone', document.getElementById('phone').value);
            
            try {
                const response = await fetch('https://script.google.com/macros/s/AKfycbyroPdZZiUoit44IjnmkM59cMDOcRhG1BKK9Pjcu5l0IJc9sUq8tEjafX6K7VtUPuhfIw/exec', {
                    method: 'POST',
                    body: formData
                });
                
                if (response.ok) {
                    showSuccessModal();
                    document.getElementById('queueForm').reset();
                } else {
                    throw new Error('Network response was not ok');
                }
            } catch (error) {
                console.error('Error:', error);
                showErrorModal('ไม่สามารถส่งข้อมูลได้ กรุณาตรวจสอบการเชื่อมต่ออินเทอร์เน็ตและลองใหม่อีกครั้ง');
            } finally {
                // Reset button
                submitBtn.innerHTML = originalContent;
                submitBtn.disabled = false;
            }
        });

        function showSuccessModal() {
            // Get form data and populate summary
            const location = document.getElementById('location').value;
            const date = document.getElementById('date').value;
            const time = document.getElementById('time').value;
            const name = document.getElementById('name').value;
            const phone = document.getElementById('phone').value;
            
            // Format date to Thai format
            const dateObj = new Date(date);
            const thaiDate = dateObj.toLocaleDateString('th-TH', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
                weekday: 'long'
            });
            
            // Format time
            const formattedTime = time + ' น.';
            
            // Format phone number
            const formattedPhone = phone.replace(/(\d{3})(\d{3})(\d{4})/, '$1-$2-$3');
            
            // Update summary fields
            document.getElementById('summaryLocation').textContent = location;
            document.getElementById('summaryDate').textContent = thaiDate;
            document.getElementById('summaryTime').textContent = formattedTime;
            document.getElementById('summaryName').textContent = name;
            document.getElementById('summaryPhone').textContent = formattedPhone;
            
            document.getElementById('successModal').classList.remove('hidden');
            document.getElementById('successModal').classList.add('flex');
        }

        function closeModal() {
            document.getElementById('successModal').classList.add('hidden');
            document.getElementById('successModal').classList.remove('flex');
        }

        function showErrorModal(message) {
            document.getElementById('errorMessage').textContent = message;
            document.getElementById('errorModal').classList.remove('hidden');
            document.getElementById('errorModal').classList.add('flex');
        }

        function closeErrorModal() {
            document.getElementById('errorModal').classList.add('hidden');
            document.getElementById('errorModal').classList.remove('flex');
        }

        // Close modals when clicking outside
        document.getElementById('successModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });

        document.getElementById('errorModal').addEventListener('click', function(e) {
            if (e.target === this) closeErrorModal();
        });
    </script>
