<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <fieldset addfieldprefix="Joomla\Component\Sptransfer\Administrator\Field">
            <field
                name="search"
                type="text"
                label="COM_SPTRANSFER_FILTER_SEARCH_LABEL"
                description="COM_SPTRANSFER_FILTER_SEARCH_DESC"
                hint="JSEARCH_FILTER"
            />
                
            <field
                name="search_field"
                label="COM_SPTRANSFER_SELECTS_FIELD_LABEL"
                description="COM_SPTRANSFER_SELECTS_FIELD_DESC"
                multiple="false"
                type="selects"
                onchange="this.form.submit();"
            />
            
            <input type="hidden" name="form_submited" value="1"/>
        </fieldset>
    </fields>
	
    <fields name="list">
        
        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
        
        <field
            name="fullordering"
            type="hidden"
            onchange="this.form.submit();"
            default="a.id DESC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.ordering ASC">JGRID_HEADING_ORDERING_ASC</option>			
        </field>

    </fields>
</form>
