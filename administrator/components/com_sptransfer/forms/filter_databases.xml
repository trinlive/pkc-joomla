<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Joomla\Component\Sptransfer\Administrator\Field">
    <fields name="filter">
        
        <field
            name="search"
            type="text"
            hint="JSEARCH_FILTER"
            description="COM_SPTRANSFER_SEARCH_BY_TABLE_NAME"
        />
        
    </fields>

    <fields name="list">
        
        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
        
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            onchange="this.form.submit();"
            default="a.created DESC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.table_name ASC">COM_SPTRANSFER_NAME_ASC</option>
            <option value="a.table_name DESC">COM_SPTRANSFER_NAME_DESC</option>	
        </field>

    </fields>
</form>
